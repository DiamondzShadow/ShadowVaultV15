# ═══════════════════════════════════════════════════════════════════════
#  HLP Keeper env — copy to .env.hlp and fill in your own values
# ═══════════════════════════════════════════════════════════════════════

# Arbitrum RPC (reuse existing)
ARB_RPC=<your-arbitrum-rpc-url>

# HyperEVM (chain 999) — provider endpoints.
# Only required if the keeper switches from REST (InfoClient) to the
# precompile fast-path for HC reads. Current implementation does NOT use it.
HL_EVM_RPC=<your-hyperevm-evm-rpc-url>
HL_NANORETH_RPC=<your-hyperevm-nanoreth-rpc-url>
HL_HYPERCORE_RPC=<your-hyperevm-hypercore-rpc-url>
HL_NANORETH_WSS=<your-hyperevm-nanoreth-wss-url>
HL_HYPERCORE_WSS=<your-hyperevm-hypercore-wss-url>

# Isolated keeper signer (NOT the v15-keeper key). Same EOA signs on
# Arbitrum and HyperCore. Fund with ~0.005 ETH on Arbitrum.
HC_KEEPER_KEY=<your-hypercore-keeper-private-key>

# Deployed HLPAdapter address on Arbitrum (fill after Phase 2 deploy)
HLP_ADAPTER_ADDR=<deployed-hlp-adapter-address>

# HLP vault identifier on HyperCore (default = mainnet HLP)
HLP_VAULT_ID=<hlp-vault-id>

# Optional: set to request a withdraw cycle of N USDC (6-dec raw units).
# Example: WITHDRAW_USD=100000000  # 100 USDC
# WITHDRAW_USD=<amount-in-6-decimals>
