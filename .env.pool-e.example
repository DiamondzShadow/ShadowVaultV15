# ═══════════════════════════════════════════════════════════════════════
#  Pool E (HyperEVM / HyperCash) env — copy to .env.pool-e, fill in your values
# ═══════════════════════════════════════════════════════════════════════

# HyperEVM mainnet RPC (chain 999)
HYPEREVM_RPC=<your-hyperevm-mainnet-rpc-url>

# Testnet (chain 998) — used for dry-run before mainnet beta
HYPEREVM_TESTNET_RPC=<your-hyperevm-testnet-rpc-url>

# Deployer EOA (must hold HYPE for gas + 1-2 USDC for verifyRoute smoke test)
DEPLOYER_KEY=<your-deployer-private-key>

# Gnosis Safe address on HyperEVM that receives protocol fees.
TREASURY_SAFE_HC=<your-hyperevm-safe-address>

# Isolated keeper EOA for state-machine nudges (KEEPER_ROLE on adapter).
# Fund with ~0.5 HYPE. DOES NOT custody USDC — only calls adapter.
KEEPER_HC=<your-keeper-eoa-address>

# After deploy, set these from config/deployed-pool-e-hc.json for the keeper:
HLP_ADAPTER_ADDR=<deployed-hlp-adapter-address>
HC_KEEPER_KEY=<your-hypercore-keeper-private-key>

# Optional — withdraw trigger for keeper (6-dec raw USDC)
# WITHDRAW_USD=<amount-in-6-decimals>
