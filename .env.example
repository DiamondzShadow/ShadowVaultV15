# ═══════════════════════════════════════════════════════════════════════
#  ShadowVaultV15 root env — copy to .env and fill in your own values
#  NEVER commit the populated .env. .gitignore already excludes it.
# ═══════════════════════════════════════════════════════════════════════

# --- RPC endpoints (bring your own provider URL) ---
ARB_RPC=<your-arbitrum-rpc-url>
POLYGON_RPC=<your-polygon-rpc-url>
HYPEREVM_RPC=<your-hyperevm-mainnet-rpc-url>
HYPEREVM_TESTNET_RPC=<your-hyperevm-testnet-rpc-url>

# --- signers (raw 0x-prefixed private keys; never share, never commit) ---
DEPLOYER_KEY=<your-deployer-private-key>
KEEPER_KEY=<your-keeper-private-key>
HC_KEEPER_KEY=<your-hypercore-keeper-private-key>
TRADER_HC_KEY=<your-hypercore-trader-private-key>

# --- block explorers ---
ETHERSCAN_API_KEY=<your-etherscan-v2-multichain-api-key>
POLYGONSCAN_API_KEY=<your-polygonscan-api-key>

# --- third-party APIs ---
ZERO_X_KEY=<your-0x-api-key>
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# --- fork test config ---
# FORK_BLOCK=<block-number>
